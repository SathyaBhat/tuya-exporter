# Tuya Configuration
TUYA_BASE_URL=https://openapi.tuyaus.com
TUYA_ACCESS_ID=your_access_id_here
TUYA_ACCESS_KEY=your_access_key_here
TUYA_DEVICE_IDS=device_id_1,device_id_2,device_id_3

# InfluxDB Configuration
INFLUXDB_HOST=http://influxdb:8086
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_DATABASE=tuya_data
INFLUXDB_MEASUREMENT=tuya_env

# InfluxDB Admin (for docker-compose only)
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=adminpassword

# Exporter Configuration
POLL_INTERVAL=30s
